{
    "name": "jardisadapter/eventdispatcher",
    "homepage": "https://jardis.io",
    "description": "PSR-14 event dispatcher for PHP with priority-ordered listeners, type-hierarchy matching, stoppable events, and deferred dispatch via EventCollector; a building block of the open-source foundation that Jardis-generated DDD code runs on",
    "type": "library",
    "license": "MIT",
    "minimum-stability": "stable",
    "prefer-stable": true,
    "authors": [
        {
            "name": "Jardis Development",
            "email": "jardisDev@headgent.com"
        }
    ],
    "require": {
        "php": ">=8.2",
        "psr/event-dispatcher": "^1.0",
        "jardissupport/contract": "^1.0"
    },
    "require-dev": {
        "phpunit/phpunit": "10.5.63",
        "phpstan/phpstan": "2.1.56",
        "squizlabs/php_codesniffer": "3.13.5"
    },
    "autoload": {
        "psr-4": {
            "JardisAdapter\\EventDispatcher\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "JardisAdapter\\EventDispatcher\\Tests\\": "tests/"
        }
    },
    "support": {
        "issues": "https://github.com/jardisAdapter/eventdispatcher/issues",
        "docs": "https://docs.jardis.io/en/adapter/eventdispatcher",
        "email": "jardisDev@headgent.com"
    },
    "keywords": [
        "event",
        "dispatcher",
        "psr-14",
        "listener",
        "domain-events",
        "event-dispatcher",
        "stoppable-events",
        "domain-driven-design",
        "hexagonal-architecture",
        "php",
        "jardis"
    ]
}
