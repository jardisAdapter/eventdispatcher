{
    "name": "jardisadapter/eventdispatcher",
    "description": "PSR-14 event dispatcher with listener registry, priority ordering, and stoppable event support",
    "type": "library",
    "license": "proprietary",
    "minimum-stability": "stable",
    "prefer-stable": true,
    "authors": [
        {
            "name": "Headgent Development",
            "email": "jardisDev@headgent.com"
        }
    ],
    "require": {
        "php": ">=8.2",
        "psr/event-dispatcher": "^1.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "phpstan/phpstan": "^2.0.4",
        "squizlabs/php_codesniffer": "^3.11.2 || ^4.0.0"
    },
    "autoload": {
        "psr-4": {
            "JardisAdapter\\EventDispatcher\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "JardisAdapter\\EventDispatcher\\Tests\\": "tests/"
        }
    },
    "homepage": "https://github.com/jardisAdapter/eventdispatcher",
    "support": {
        "issues": "https://github.com/jardisAdapter/eventdispatcher/issues",
        "email": "jardisDev@headgent.com"
    },
    "keywords": [
        "event",
        "dispatcher",
        "psr-14",
        "listener",
        "domain driven design",
        "jardis",
        "Headgent"
    ]
}
